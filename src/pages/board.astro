---
// Board Portal — /board — static mode, demo data only
import Layout from '../layouts/Layout.astro';
import { demoBoardsFixed } from '../lib/db';

const boards = demoBoardsFixed;
const isLoggedIn = false; // auth is client-side stub
---
<Layout title="Styreportal" activeNav="boards">
  <div class="container" style="max-width: 960px; margin: 2rem auto; padding: 0 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
      <h1 style="font-size: 2rem; color: var(--ink);">Dine styrer</h1>
      <a href="/login" class="btn-primary" style="text-decoration: none;">Logg inn for tilgang</a>
    </div>

    <div style="display: grid; gap: 16px;">
      {boards.map(board => (
        <a href={`/board/${board.id}`} style="text-decoration: none; color: inherit; display: block; background: white; border: 1px solid rgba(16,36,31,0.10); border-radius: 16px; padding: 24px; transition: all 0.2s;">
          <div style="display: flex; justify-content: space-between; align-items: start; gap: 16px;">
            <div>
              <h2 style="font-size: 1.25rem; margin: 0 0 6px 0;">{board.name}</h2>
              <p style="font-family: system-ui, sans-serif; font-size: 0.875rem; color: var(--muted); margin: 0;">
                {board.members_count || 0} medlemmer · Forrige møte: {board.last_meeting || 'Ingen'}
              </p>
              <div style="margin-top: 8px;">
                <span class="status-pill" style="background: {board.status === 'active' ? 'rgba(31,111,91,0.12)' : 'rgba(200,180,30,0.15)'}; color: {board.status === 'active' ? 'var(--accent)' : '#8a7500'}; font-family: system-ui, sans-serif; font-size: 0.75rem; font-weight: 600; padding: 4px 12px; border-radius: 100px;">
                  {board.status === 'active' ? 'Aktiv' : 'Pilot'}
                </span>
              </div>
            </div>
            <span style="font-family: system-ui, sans-serif; font-size: 0.875rem; color: var(--muted); white-space: nowrap;">
              → Vis detaljer
            </span>
          </div>
        </a>
      ))}
    </div>

    <div style="margin-top: 2rem; text-align: center;">
      <p style="font-family: system-ui, sans-serif; color: var(--muted); font-size: 0.9rem;">
        Dette er demovyer. Logg inn for å opprette dine egne.
      </p>
    </div>
  </div>
</Layout>

<style>
  a:hover { text-decoration: none; }
  a:hover > div { box-shadow: 0 4px 20px rgba(16,36,31,0.10); transform: translateY(-2px); }
  .btn-primary {
    background: var(--accent); color: #fff;
    padding: 10px 24px; border-radius: 100px;
    font-family: system-ui, sans-serif; font-size: 0.9rem; font-weight: 600;
    border: none; cursor: pointer;
  }
</style>
