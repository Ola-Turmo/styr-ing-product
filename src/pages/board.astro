---
// Board Portal Page — /board
import Layout from '../layouts/Layout.astro';
import { getSession } from '../session';
import { demoBoards } from '../lib/db';

const env = (Astro.locals.runtime as any)?.env;
const session = await getSession(Astro.request, env);

let boards: any[] = [];
let isDemo = false;

if (env?.DB && session) {
  try {
    const result = await env.DB.prepare(
      'SELECT b.* FROM boards b JOIN user_boards ub ON b.id = ub.board_id WHERE ub.user_id = ? ORDER BY b.created_at DESC'
    ).bind(session.userId).all();
    boards = result.results;
  } catch { isDemo = true; }
} else {
  isDemo = true;
  boards = demoBoards;
}
---
<Layout title="Styreportal" activeNav="board">
  <div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
      <div>
        <h1 style="font-size: 2rem; color: #065f46;">Styreportal</h1>
        <p style="color: #666; margin-top: 0.25rem;">
          {session ? `Velkommen, ${session.name}` : 'Oversikt over dine styrer'}
        </p>
      </div>
      <div style="display: flex; gap: 0.5rem;">
        {!session && <a href="/login" class="btn-secondary" style="font-size: 0.85rem;">Logg inn</a>}
        {session && <a href="javascript:void(0)" onclick="showNewBoard()" class="btn-primary" style="font-size: 0.85rem;">+ Nytt styre</a>}
      </div>
    </div>

    {isDemo && (
      <div style="background: #fffbeb; border: 1px solid #fde68a; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.85rem; color: #92400e;">
        📋 <strong>Demo-modus</strong> — Dette er eksempeldata. <a href="/signup" style="color: #065f46; font-weight: 600;">Opprett konto</a> for å komme i gang med ekte styredata.
      </div>
    )}

    {boards.length === 0 && (
      <div style="text-align: center; padding: 4rem 2rem; background: white; border-radius: 12px; box-shadow: 0 1px 4px rgba(0,0,0,0.08);">
        <div style="font-size: 3rem; margin-bottom: 1rem;">📋</div>
        <h2 style="color: #065f46; margin-bottom: 0.5rem;">Ingen styrer ennå</h2>
        <p style="color: #666; margin-bottom: 1.5rem;">Opprett ditt første styre for å komme i gang.</p>
        {session ? <a href="javascript:void(0)" onclick="showNewBoard()" class="btn-primary">+ Opprett styre</a> : <a href="/signup" class="btn-primary">Opprett konto</a>}
      </div>
    )}

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1rem;">
      {boards.map((board: any) => (
        <a href={`/board/${board.id}`} style="text-decoration: none; color: inherit;">
          <div style="background: white; border-radius: 12px; padding: 1.5rem; box-shadow: 0 1px 4px rgba(0,0,0,0.08); border-left: 4px solid #065f46; transition: transform 0.15s, box-shadow 0.15s; cursor: pointer;">
            <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 0.75rem;">
              <h3 style="font-size: 1.15rem; color: #1a1a1a;">{board.name}</h3>
              <span class={`badge ${board.status === 'active' ? 'badge-green' : board.status === 'pilot' ? 'badge-yellow' : 'badge-blue'}`}>
                {board.status === 'pilot' ? 'Pilot' : board.status === 'active' ? 'Aktiv' : board.status}
              </span>
            </div>
            {board.description && <p style="color: #555; font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.4;">{board.description}</p>}
            <div style="display: flex; gap: 1.5rem; font-size: 0.8rem; color: #666;">
              <span>👥 {board.memberCount || board.members_count || '?'} medlemmer</span>
              <span>📅 {board.nextMeeting || board.next_meeting || 'Ingen møter'}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    {boards.length > 0 && (
      <div style="margin-top: 1.5rem; text-align: center;">
        <p style="font-size: 0.85rem; color: #888;">
          {session ? 'Trenger du hjelp?' : 'Har du allerede et styre?'} <a href="mailto:sales@styr.ing" style="color: #065f46; font-weight: 600;">Kontakt oss</a>
        </p>
      </div>
    )}
  </div>
</Layout>

<!-- New Board Modal -->
<div id="new-board-modal" class="modal">
  <div class="modal-content">
    <h3>Opprett nytt styre</h3>
    <form id="new-board-form" class="form-row">
      <label>Navn på styret <input type="text" name="name" required placeholder="F.eks. Styret 2026" /></label>
      <label>Beskrivelse <input type="text" name="description" placeholder="Kort beskrivelse av styret" /></label>
      <label>Organisasjonsnummer <input type="text" name="org_number" placeholder="Valgfritt" /></label>
      <div class="form-actions">
        <button type="button" onclick="closeModal('new-board-modal')" class="btn-secondary">Avbryt</button>
        <button type="submit" class="btn-primary">Opprett styre</button>
      </div>
    </form>
  </div>
</div>

<style>
  .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 200; justify-content: center; align-items: center; }
  .modal.active { display: flex; }
  .modal-content { background: white; border-radius: 16px; padding: 2rem; max-width: 480px; width: 90%; }
  .modal-content h3 { color: #065f46; margin-bottom: 1.5rem; }
  .form-row { display: flex; flex-direction: column; gap: 1rem; }
  .form-row label { font-weight: 600; font-size: 0.85rem; }
  .form-row input { padding: 0.6rem; border: 1.5px solid #ddd; border-radius: 8px; font-size: 0.9rem; }
  .form-actions { display: flex; gap: 0.75rem; margin-top: 1.5rem; justify-content: flex-end; }
</style>

<script>
  function showNewBoard() { document.getElementById('new-board-modal')!.classList.add('active'); }
  function closeModal(id: string) { document.getElementById(id)!.classList.remove('active'); }
  document.querySelectorAll('.modal').forEach(m => m.addEventListener('click', (e) => { if (e.target === m) closeModal(m.id); }));
  
  document.getElementById('new-board-form')?.addEventListener('submit', async (e) => {
    e.preventDefault(); const f = new FormData(e.target as HTMLFormElement);
    try {
      const resp = await fetch('/api/boards', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ name: f.get('name'), description: f.get('description'), org_number: f.get('org_number') }) });
      const data = await resp.json();
      if (data.id) window.location.href = `/board/${data.id}`;
      else alert('Feil ved opprettelse');
    } catch { alert('Nettverksfeil'); }
  });
</script>
