---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Opprett konto" activeNav="">
  <div class="container" style="max-width: 440px; margin: 4rem auto;">
    <h1 style="font-size: 1.8rem; color: #065f46; margin-bottom: 0.5rem; text-align: center;">Opprett konto</h1>
    <p style="text-align: center; color: #666; margin-bottom: 2rem;">Kom i gang med din styreportal</p>
    
    <form id="signup-form" style="display: flex; flex-direction: column; gap: 1rem;">
      <div>
        <label for="name" style="display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 0.3rem;">Navn</label>
        <input type="text" id="name" required style="width: 100%; padding: 0.75rem; border: 1.5px solid #ddd; border-radius: 8px; font-size: 1rem;" placeholder="Ditt fulle navn" />
      </div>
      <div>
        <label for="email" style="display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 0.3rem;">E-post</label>
        <input type="email" id="email" required style="width: 100%; padding: 0.75rem; border: 1.5px solid #ddd; border-radius: 8px; font-size: 1rem;" placeholder="din@bedrift.no" />
      </div>
      <div>
        <label for="password" style="display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 0.3rem;">Passord</label>
        <input type="password" id="password" required minlength="8" style="width: 100%; padding: 0.75rem; border: 1.5px solid #ddd; border-radius: 8px; font-size: 1rem;" placeholder="Minst 8 tegn" />
      </div>
      <div id="error" style="color: #991b1b; font-size: 0.85rem; display: none;"></div>
      <button type="submit" class="btn-primary" style="width: 100%; padding: 0.85rem; font-size: 1rem;">Opprett konto</button>
    </form>
    
    <p style="text-align: center; margin-top: 1.5rem; font-size: 0.9rem; color: #666;">
      Har du konto? <a href="/login" style="color: #065f46; font-weight: 600;">Logg inn</a>
    </p>
  </div>
</Layout>

<script>
  document.getElementById('signup-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = (document.getElementById('name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const btn = e.target.querySelector('button')!;
    btn.textContent = 'Oppretter...'; btn.disabled = true;
    try {
      const resp = await fetch('/api/auth/signup', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, email, password }) });
      const data = await resp.json();
      if (data.ok) { window.location.href = '/board'; }
      else { document.getElementById('error')!.textContent = data.error; document.getElementById('error')!.style.display = 'block'; }
    } catch { document.getElementById('error')!.textContent = 'Nettverksfeil.'; document.getElementById('error')!.style.display = 'block'; }
    btn.textContent = 'Opprett konto'; btn.disabled = false;
  });
</script>
