---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Logg inn" activeNav="">
  <div class="container" style="max-width: 440px; margin: 4rem auto;">
    <h1 style="font-size: 1.8rem; color: #065f46; margin-bottom: 0.5rem; text-align: center;">Logg inn</h1>
    <p style="text-align: center; color: #666; margin-bottom: 2rem;">Tilgang til din styreportal</p>
    
    <form id="login-form" style="display: flex; flex-direction: column; gap: 1rem;">
      <div>
        <label for="email" style="display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 0.3rem;">E-post</label>
        <input type="email" id="email" required style="width: 100%; padding: 0.75rem; border: 1.5px solid #ddd; border-radius: 8px; font-size: 1rem;" placeholder="din@bedrift.no" />
      </div>
      <div>
        <label for="password" style="display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 0.3rem;">Passord</label>
        <input type="password" id="password" required minlength="8" style="width: 100%; padding: 0.75rem; border: 1.5px solid #ddd; border-radius: 8px; font-size: 1rem;" placeholder="••••••••" />
      </div>
      <div id="error" style="color: #991b1b; font-size: 0.85rem; display: none;"></div>
      <button type="submit" class="btn-primary" style="width: 100%; padding: 0.85rem; font-size: 1rem;">Logg inn</button>
    </form>
    
    <p style="text-align: center; margin-top: 1.5rem; font-size: 0.9rem; color: #666;">
      Ingen konto? <a href="/signup" style="color: #065f46; font-weight: 600;">Opprett konto</a>
    </p>
  </div>
</Layout>

<script>
  document.getElementById('login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const btn = e.target.querySelector('button')!;
    btn.textContent = 'Logger inn...';
    btn.disabled = true;
    
    try {
      const resp = await fetch('/api/auth/login', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password })
      });
      const data = await resp.json();
      if (data.ok) { window.location.href = '/board'; }
      else { document.getElementById('error')!.textContent = data.error; document.getElementById('error')!.style.display = 'block'; }
    } catch {
      document.getElementById('error')!.textContent = 'Nettverksfeil. Prøv igjen.';
      document.getElementById('error')!.style.display = 'block';
    }
    btn.textContent = 'Logg inn';
    btn.disabled = false;
  });
</script>
