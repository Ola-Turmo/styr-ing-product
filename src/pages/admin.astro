---
import Layout from '../layouts/Layout.astro';
import { demoBoardsFixed, demoComplianceEvents, demoControls, demoDemoRequests } from '../lib/db';

const boards = demoBoardsFixed;
const events = demoComplianceEvents;
const controls = demoControls;
const requests = demoDemoRequests;
---
<Layout title="Admin" activeNav="">
  <div class="container" style="max-width: 960px; margin: 2rem auto; padding: 0 20px;">
    <h1 style="font-size: 2rem; margin-bottom: 1.5rem;">Admin Dashboard</h1>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 2rem;">
      <div class="stat-card">
        <div class="stat-num">{boards.length}</div>
        <div class="stat-label">Aktive styrer</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{events.length}</div>
        <div class="stat-label">Compliance-hendelser</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{controls.length}</div>
        <div class="stat-label">Kontrollpunkter</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{requests.length}</div>
        <div class="stat-label">Demo-forespørsler</div>
      </div>
    </div>

    <section style="margin-bottom: 2rem;">
      <h2 style="font-size: 1.25rem; margin-bottom: 1rem;">Demo-forespørsler</h2>
      {requests.length === 0 ? (
        <p style="font-family: system-ui, sans-serif; color: var(--muted);">Ingen forespørsler.</p>
      ) : (
        <div style="overflow-x: auto;">
          <table style="width: 100%; border-collapse: collapse; font-family: system-ui, sans-serif;">
            <thead>
              <tr style="border-bottom: 2px solid rgba(16,36,31,0.08); text-align: left;">
                <th style="padding: 10px 14px; font-size: 0.8rem; color: var(--muted);">Navn</th>
                <th style="padding: 10px 14px; font-size: 0.8rem; color: var(--muted);">Bedrift</th>
                <th style="padding: 10px 14px; font-size: 0.8rem; color: var(--muted);">E-post</th>
                <th style="padding: 10px 14px; font-size: 0.8rem; color: var(--muted);">Status</th>
              </tr>
            </thead>
            <tbody>
              {requests.map(r => (
                <tr style="border-bottom: 1px solid rgba(16,36,31,0.05);">
                  <td style="padding: 10px 14px; font-size: 0.875rem;">{r.name}</td>
                  <td style="padding: 10px 14px; font-size: 0.875rem;">{r.company}</td>
                  <td style="padding: 10px 14px; font-size: 0.875rem; color: var(--muted);">{r.email}</td>
                  <td style="padding: 10px 14px;">
                    <span style="display: inline-block; background: {r.status === 'new' ? 'rgba(216,169,77,0.15)' : 'rgba(31,111,91,0.10)'}; color: {r.status === 'new' ? '#8a7500' : 'var(--accent)'}; font-size: 0.75rem; font-weight: 600; padding: 3px 10px; border-radius: 100px;">
                      {r.status === 'new' ? 'Ny' : 'Kontaktet'}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <div style="text-align: center; padding: 1.5rem; background: rgba(31,111,91,0.06); border-radius: 12px;">
      <p style="font-family: system-ui, sans-serif; font-size: 0.9rem; color: var(--muted); margin: 0;">
        Demo-dashboard. <a href="/login" style="color: var(--accent); font-weight: 600;">Logg inn</a> for live admin-panel.
      </p>
    </div>
  </div>
</Layout>

<style>
  .stat-card {
    background: white;
    border: 1px solid rgba(16,36,31,0.08);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }
  .stat-num { font-size: 1.75rem; font-weight: 700; color: var(--accent); }
  .stat-label { font-family: system-ui, sans-serif; font-size: 0.8rem; color: var(--muted); margin-top: 2px; }
</style>
