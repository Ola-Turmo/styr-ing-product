---
import Layout from '../layouts/Layout.astro';
import { demoComplianceEvents } from '../lib/db';

const events = demoComplianceEvents;
const completed = events.filter(e => e.status === 'completed').length;
const total = events.length;
const completionRate = total > 0 ? Math.round((completed / total) * 100) : 0;
---
<Layout title="Compliance-kalender" activeNav="compliance">
  <div class="container" style="max-width: 960px; margin: 2rem auto; padding: 0 20px;">
    <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">Compliance-kalender</h1>
    <p style="font-family: system-ui, sans-serif; color: var(--muted); margin: 0 0 2rem 0;">
      Hold oversikt over norske regulatoriske frister. Få påminnelser om viktige datoer.
    </p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 2rem;">
      <div class="stat-card">
        <div class="stat-num">{total}</div>
        <div class="stat-label">Hendelser</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{completed}</div>
        <div class="stat-label">Fullført</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{completionRate}%</div>
        <div class="stat-label">Grad</div>
      </div>
    </div>

    <div style="overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; font-family: system-ui, sans-serif;">
        <thead>
          <tr style="text-align: left; border-bottom: 2px solid rgba(16,36,31,0.08);">
            <th style="padding: 12px 16px; font-size: 0.8rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em;">Frist</th>
            <th style="padding: 12px 16px; font-size: 0.8rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em;">Hendelse</th>
            <th style="padding: 12px 16px; font-size: 0.8rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em;">Myndighet</th>
            <th style="padding: 12px 16px; font-size: 0.8rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em;">Status</th>
          </tr>
        </thead>
        <tbody>
          {events.map(event => (
            <tr style="border-bottom: 1px solid rgba(16,36,31,0.05);">
              <td style="padding: 14px 16px; font-weight: 600; font-size: 0.9rem;">{event.deadline}</td>
              <td style="padding: 14px 16px; font-size: 0.9rem;">{event.title}</td>
              <td style="padding: 14px 16px; font-size: 0.85rem; color: var(--muted);">{event.authority}</td>
              <td style="padding: 14px 16px;">
                <span style="display: inline-block; background: {event.status === 'completed' ? 'rgba(31,111,91,0.10)' : event.status === 'in_progress' ? 'rgba(216,169,77,0.15)' : 'rgba(150,150,150,0.12)'}; color: {event.status === 'completed' ? 'var(--accent)' : event.status === 'in_progress' ? '#8a7500' : 'var(--muted)'}; font-size: 0.75rem; font-weight: 600; padding: 4px 12px; border-radius: 100px;">
                  {event.status === 'completed' ? 'Fullført' : event.status === 'in_progress' ? 'Pågår' : 'Venter'}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div style="text-align: center; margin-top: 2rem; padding: 1.5rem; background: rgba(31,111,91,0.06); border-radius: 12px;">
      <p style="font-family: system-ui, sans-serif; font-size: 0.9rem; color: var(--muted); margin: 0;">
        Demo-data. <a href="/login" style="color: var(--accent); font-weight: 600;">Logg inn</a> for å administrere dine egne compliance-hendelser.
      </p>
    </div>
  </div>
</Layout>

<style>
  .stat-card {
    background: white;
    border: 1px solid rgba(16,36,31,0.08);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }
  .stat-num { font-size: 1.75rem; font-weight: 700; color: var(--accent); }
  .stat-label { font-family: system-ui, sans-serif; font-size: 0.8rem; color: var(--muted); margin-top: 2px; }
</style>
