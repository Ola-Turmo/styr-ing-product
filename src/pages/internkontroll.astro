---
import Layout from '../layouts/Layout.astro';
import { demoControls } from '../lib/db';

const controls = demoControls;
const approved = controls.filter(c => c.status === 'approved').length;
const pending = controls.filter(c => c.status === 'pending').length;
---
<Layout title="Internkontroll" activeNav="internkontroll">
  <div class="container" style="max-width: 960px; margin: 2rem auto; padding: 0 20px;">
    <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">Internkontroll</h1>
    <p style="font-family: system-ui, sans-serif; color: var(--muted); margin: 0 0 2rem 0;">
      COSO-basert internkontroll for norske virksomheter. Dokumenter kontroller, avvik og risikovurderinger.
    </p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 2rem;">
      <div class="stat-card">
        <div class="stat-num">{controls.length}</div>
        <div class="stat-label">Kontrollpunkter</div>
      </div>
      <div class="stat-card">
        <div class="stat-num" style="color: var(--accent);">{approved}</div>
        <div class="stat-label">Godkjent</div>
      </div>
      <div class="stat-card">
        <div class="stat-num" style="color: #8a7500;">{pending}</div>
        <div class="stat-label">Til vurdering</div>
      </div>
    </div>

    <div style="display: grid; gap: 16px;">
      {controls.map(control => (
        <div class="control-card">
          <div style="display: flex; justify-content: space-between; align-items: start; gap: 16px; margin-bottom: 8px;">
            <h3 style="font-size: 1.05rem; margin: 0;">{control.title}</h3>
            <span class="control-badge badge-{control.status}">
              {control.status === 'approved' ? 'Godkjent' : control.status === 'pending' ? 'Til vurdering' : 'Utkast'}
            </span>
          </div>
          <p style="font-family: system-ui, sans-serif; font-size: 0.875rem; color: var(--muted); margin: 0 0 12px 0; line-height: 1.5;">
            {control.description || ''}
          </p>
          <div style="display: flex; gap: 16px; font-family: system-ui, sans-serif; font-size: 0.8rem; color: var(--muted);">
            <span>🔍 {control.frequency || 'Årlig'} gjennomgang</span>
            <span>📋 Ansvar: {control.responsible || 'Styreleder'}</span>
            {control.last_review && <span>📅 Sist vurdert: {control.last_review}</span>}
          </div>
        </div>
      ))}
    </div>

    <div style="text-align: center; margin-top: 2rem; padding: 1.5rem; background: rgba(31,111,91,0.06); border-radius: 12px;">
      <p style="font-family: system-ui, sans-serif; font-size: 0.9rem; color: var(--muted); margin: 0;">
        Demo-data. <a href="/login" style="color: var(--accent); font-weight: 600;">Logg inn</a> for å sette opp din egen internkontroll.
      </p>
    </div>
  </div>
</Layout>

<style>
  .stat-card {
    background: white;
    border: 1px solid rgba(16,36,31,0.08);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }
  .stat-num { font-size: 1.75rem; font-weight: 700; color: var(--ink); }
  .stat-label { font-family: system-ui, sans-serif; font-size: 0.8rem; color: var(--muted); margin-top: 2px; }
  
  .control-card {
    background: white;
    border: 1px solid rgba(16,36,31,0.08);
    border-radius: 14px;
    padding: 20px 24px;
    transition: box-shadow 0.2s;
  }
  .control-card:hover { box-shadow: 0 4px 16px rgba(16,36,31,0.06); }
  
  .control-badge {
    font-family: system-ui, sans-serif; font-size: 0.75rem; font-weight: 600;
    padding: 3px 12px; border-radius: 100px; white-space: nowrap;
  }
  .badge-approved { background: rgba(31,111,91,0.10); color: var(--accent); }
  .badge-pending { background: rgba(216,169,77,0.15); color: #8a7500; }
  .badge-draft { background: rgba(150,150,150,0.12); color: var(--muted); }
</style>
