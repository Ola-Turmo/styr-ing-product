---
// Actions Page — Aksjonsoppfølging
import Layout from '../../../layouts/Layout.astro';
import { demoBoardsFixed } from '../../../lib/db';
import { demoActionItems } from '../../../lib/demo-data-extended';

export function getStaticPaths() {
  return demoBoardsFixed.map(board => ({ params: { id: board.id } }));
}

const { id } = Astro.params;
const board = demoBoardsFixed.find(b => b.id === id) || demoBoardsFixed[0];
const all = demoActionItems.filter(a => a.board_id === id);
const open = all.filter(a => a.status !== 'completed');
const completed = all.filter(a => a.status === 'completed');
const byStatus = (s: string) => all.filter(a => a.status === s);
const priorityLabels: Record<string,string> = {critical:'Kritisk',high:'Høy',medium:'Medium',low:'Lav'};
const priorityColors: Record<string,string> = {critical:'#c0392b',high:'#e67e22',medium:'#f39c12',low:'#95a5a6'};
const sourceLabels: Record<string,string> = {meeting:'Møte',resolution:'Vedtak',compliance:'Compliance',manual:'Manuell'};
---
<Layout title={`Aksjoner — ${board.name}`} activeNav="boards">
<div class="container">
  <a href={`/board/${id}`} class="back-link">← Tilbake til {board.name}</a>
  
  <div class="header">
    <h1>Aksjonsoppfølging</h1>
    <div class="header-stats">
      <span class="stat-chip open">{open.length} åpne</span>
      <span class="stat-chip done">{completed.length} fullførte</span>
    </div>
  </div>

  {open.length > 0 && (
    <div class="section">
      <h2>Åpne aksjoner</h2>
      {['critical','high','medium','low'].map(pri => {
        const items = open.filter(a => a.priority === pri);
        if (items.length === 0) return null;
        return items.map(a => (
          <div class="action-card">
            <div class="ac-priority" style={`background:${priorityColors[pri]}`}></div>
            <div class="ac-body">
              <div class="ac-header">
                <strong>{a.title}</strong>
                <span class={`ac-status ac-${a.status}`}>{a.status === 'blocked' ? '⚠ Blokkert' : a.status === 'in_progress' ? '◷ Under arbeid' : '○ Åpen'}</span>
              </div>
              <p class="ac-desc">{a.description}</p>
              <div class="ac-meta">
                <span>👤 {a.assigned_to_name}</span>
                <span>📅 Frist: {a.due_date}</span>
                <span>📋 Kilde: {sourceLabels[a.source]}</span>
                <span class="ac-priority-label" style={`color:${priorityColors[pri]}`}>{priorityLabels[pri]}</span>
              </div>
            </div>
          </div>
        ));
      })}
    </div>
  )}

  {completed.length > 0 && (
    <div class="section">
      <h2>Fullførte aksjoner</h2>
      {completed.map(a => (
        <div class="action-card completed">
          <div class="ac-priority" style="background:#27ae60"></div>
          <div class="ac-body">
            <div class="ac-header">
              <strong>{a.title}</strong>
              <span class="ac-done">✓ Fullført</span>
            </div>
            <div class="ac-meta">
              <span>👤 {a.assigned_to_name}</span>
              <span>{a.completed_at || a.due_date}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}

  {all.length === 0 && <p class="empty">Ingen aksjoner registrert.</p>}
  <div class="demo-notice">Demo-data. <a href="/login">Logg inn</a> for aksjonsoppfølging i ditt styre.</div>
</div>
</Layout>

<style>
.container { max-width: 800px; margin: 1.5rem auto; padding: 0 20px; }
.back-link { font-family: system-ui, sans-serif; font-size: 0.85rem; color: var(--muted); text-decoration: none; }
.back-link:hover { color: var(--accent); }
.header { display: flex; justify-content: space-between; align-items: center; margin: 1rem 0 2rem; }
.header h1 { font-size: 1.6rem; margin: 0; }
.header-stats { display: flex; gap: 8px; }
.stat-chip { font-family: system-ui, sans-serif; font-size: 0.78rem; font-weight: 700; padding: 4px 12px; border-radius: 100px; }
.stat-chip.open { background: rgba(243,156,18,0.12); color: #8a7500; }
.stat-chip.done { background: rgba(39,174,96,0.12); color: #27ae60; }
.section { margin-bottom: 2rem; }
.section h2 { font-size: 1.1rem; margin: 0 0 1rem 0; }
.action-card {
  display: flex; gap: 14px; padding: 16px; background: white;
  border: 1px solid rgba(16,36,31,0.08); border-radius: 12px; margin-bottom: 8px;
}
.action-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
.action-card.completed { opacity: 0.6; }
.ac-priority { width: 4px; border-radius: 2px; flex-shrink: 0; }
.ac-body { flex: 1; min-width: 0; }
.ac-header { display: flex; justify-content: space-between; align-items: start; gap: 12px; margin-bottom: 6px; }
.ac-header strong { font-family: system-ui, sans-serif; font-size: 0.95rem; }
.ac-status { font-family: system-ui, sans-serif; font-size: 0.75rem; font-weight: 600; padding: 2px 10px; border-radius: 100px; white-space: nowrap; }
.ac-blocked { background: rgba(192,57,43,0.10); color: #c0392b; }
.ac-in_progress { background: rgba(243,156,18,0.10); color: #8a7500; }
.ac-open { background: rgba(149,165,166,0.10); color: #7f8c8d; }
.ac-done { font-family: system-ui, sans-serif; font-size: 0.75rem; color: #27ae60; font-weight: 600; }
.ac-desc { font-family: system-ui, sans-serif; font-size: 0.82rem; color: var(--muted); margin: 0 0 8px 0; line-height: 1.4; }
.ac-meta { display: flex; gap: 14px; flex-wrap: wrap; font-family: system-ui, sans-serif; font-size: 0.75rem; color: var(--muted); }
.ac-priority-label { font-weight: 700; }
.empty { text-align: center; padding: 3rem; color: var(--muted); font-family: system-ui, sans-serif; }
.demo-notice { text-align: center; padding: 1.5rem; margin-top: 2rem; background: rgba(31,111,91,0.06); border-radius: 12px; font-family: system-ui, sans-serif; font-size: 0.85rem; color: var(--muted); }
.demo-notice a { color: var(--accent); font-weight: 600; }
</style>