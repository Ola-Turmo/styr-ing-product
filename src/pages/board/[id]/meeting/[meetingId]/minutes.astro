---
// Minutes Drafting Page — AI-assisted meeting minutes
import Layout from '../../../../../layouts/Layout.astro';
import { demoMeetingsExtended } from '../../../../../lib/demo-data-extended';

export function getStaticPaths() {
  return demoMeetingsExtended.map(m => ({ params: { id: m.board_id, meetingId: m.id } }));
}

const { id, meetingId } = Astro.params;
const meeting = demoMeetingsExtended.find(m => m.id === meetingId);
if (!meeting) return Astro.redirect('/board/' + id);

const isApproved = meeting.minutes_status === 'approved';
const completed = meeting.status === 'completed';

// Prepare render data
const sections = meeting.agenda_items.map(item => {
  const typeLabel = item.type === 'decision' ? 'Beslutningssak' :
    item.type === 'discussion' ? 'Drøftelsessak' :
    item.type === 'election' ? 'Valg' : 'Orientering';
  
  let bodyHtml = '';
  let evidenceHtml = '';
  let decisionHtml = '';
  let confidenceLevel = 'high';
  let confidenceText = 'AI-konfidens: Høy — basert på vedtaksregister og møtereferat';

  if (item.status === 'completed') {
    const preparer = item.prepared_by || 'Møteleder';
    
    if (item.type === 'decision') {
      bodyHtml = (item.prepared_by ? item.prepared_by + ' presenterte saken. ' : '') +
        'Styret diskuterte ' + item.title.toLowerCase() + '.';
      confidenceLevel = 'high';
    } else if (item.type === 'discussion') {
      bodyHtml = (item.prepared_by ? item.prepared_by + ' innledet til diskusjon. ' : '') +
        'Styret drøftet ' + item.title.toLowerCase() + '. Synspunkter og innspill er dokumentert i møtereferatet.';
      confidenceLevel = 'medium';
      confidenceText = 'AI-konfidens: Medium — basert på tale-til-tekst. Gjennomgås av referent.';
    } else if (item.type === 'election') {
      bodyHtml = (item.prepared_by ? item.prepared_by + ' presenterte saken. ' : '') +
        'Styret gjennomførte valg. Resultatet fremgår av vedtaksregisteret.';
    } else {
      bodyHtml = (item.prepared_by ? item.prepared_by + ' orienterte om ' + item.title.toLowerCase() + '. ' : '') +
        'Styret tok informasjonen til etterretning.';
    }
    evidenceHtml = 'Kilde: ' + preparer + ' · Varighet: ' + item.duration_min + ' min' +
      (item.documents && item.documents.length > 0 ? ' · Vedlegg: ' + item.documents.join(', ') : '');
    decisionHtml = item.decision || '';
  }

  return { ...item, typeLabel, bodyHtml, evidenceHtml, decisionHtml, confidenceLevel, confidenceText };
});

const statusStyles = { draft:'#f0f9f4', scheduled:'#e8f5e9', in_progress:'#ffeaa7', completed:'#dfe6e9', archived:'#eee' };
const statusLabels = { draft:'Kladd', scheduled:'Planlagt', in_progress:'Pågår', completed:'Fullført', archived:'Arkivert' };
---

<Layout title={'Protokoll — ' + meeting.title} activeNav="boards">
<div class="minutes-page">
  <a href={'/board/' + id + '/meeting/' + meetingId} class="back-link">← Tilbake til møtet</a>

  <div class="top-bar">
    <h1>Protokoll</h1>
    <div class="top-actions">
      {!isApproved && <button class="btn-primary">Send til godkjenning</button>}
      <button class="btn-outline">Last ned PDF</button>
      <button class="btn-outline">Eksporter Word</button>
    </div>
  </div>

  <div class="meta-bar">
    <span>{meeting.title}</span><span>·</span><span>{meeting.date}</span>
    {isApproved && <span class="badge ok">✓ Godkjent</span>}
    {!isApproved && completed && <span class="badge warn">Utkast</span>}
    {!completed && <span class="badge info">Møte ikke fullført</span>}
  </div>

  {!completed && (
    <div class="empty-state">
      <div class="empty-icon">📝</div>
      <h2>Protokoll ikke tilgjengelig</h2>
      <p>Protokollen genereres automatisk når møtet er fullført. AI-assistenten vil utarbeide et utkast basert på agenda, vedtak og møtereferat.</p>
    </div>
  )}

  {completed && (
    <div class="minutes-body">
      <div class="provenance-banner">
        <span class="prov-icon">🤖</span>
        <div>
          <strong>AI-assistert protokoll</strong>
          <p>Dette utkastet er generert fra: {meeting.agenda_items.length} agendapunkter og møtereferat. Gjennomgå og rediger før godkjenning.</p>
        </div>
      </div>

      <div class="minutes-meta-grid">
        <div><strong>Dato:</strong> {meeting.date}</div>
        <div><strong>Tid:</strong> {meeting.time}</div>
        <div><strong>Sted:</strong> {meeting.location}</div>
        <div><strong>Møteleder:</strong> Ola Turmo (Styreleder)</div>
        <div><strong>Referent:</strong> Kari Sekretær</div>
        <div><strong>Status:</strong> {isApproved ? 'Godkjent' : 'Utkast — ikke godkjent'}</div>
      </div>

      <hr class="section-divider"/>

      {sections.map(item => (
        <div class="minute-section">
          <div class="section-head">
            <span class="sec-num">{item.number}.</span>
            <strong>{item.title}</strong>
            <span class="sec-type">{item.typeLabel}</span>
          </div>

          {item.status === 'completed' ? (
            <div class="section-body">
              <p>{item.bodyHtml}</p>
              <div class="evidence-line">
                <span>🔗</span>
                <span>{item.evidenceHtml}</span>
              </div>
              
              {item.decisionHtml && (
                <div class="decision-box">
                  <div class="dec-label">Beslutning</div>
                  <p>{item.decisionHtml}</p>
                  <div class="vote-line">Votering: Enstemmig</div>
                </div>
              )}

              {(item.type === 'decision' || item.type === 'discussion') && (
                <div class="confidence-line">
                  <span class={'conf-dot ' + (item.confidenceLevel === 'high' ? 'conf-high' : 'conf-medium')}></span>
                  {item.confidenceText}
                </div>
              )}

              {item.notes && (
                <div class="notes-box">
                  <strong>Referents notater:</strong>
                  <p>{item.notes}</p>
                </div>
              )}
            </div>
          ) : (
            <div class="section-empty">
              <p>Innhold genereres når saksbehandlingen er fullført</p>
            </div>
          )}
        </div>
      ))}

      <hr class="section-divider"/>

      <div class="signature-block">
        <h3>Signering</h3>
        <div class="sig-grid">
          <div class="sig-line">
            <span class="sig-label">Møteleder</span>
            <span class="sig-name">Ola Turmo</span>
            <span class="sig-status">✍️ {isApproved ? 'Signert' : 'Venter'}</span>
          </div>
          <div class="sig-line">
            <span class="sig-label">Referent</span>
            <span class="sig-name">Kari Sekretær</span>
            <span class="sig-status">✍️ {isApproved ? 'Signert' : 'Venter'}</span>
          </div>
        </div>
      </div>
    </div>
  )}
</div>
</Layout>

<style>
.minutes-page { max-width: 780px; margin: 2rem auto; padding: 0 20px; }
.back-link { font-family: system-ui, sans-serif; font-size: 0.85rem; color: var(--muted); text-decoration: none; }

.top-bar { display: flex; justify-content: space-between; align-items: flex-start; margin: 1rem 0; }
.top-bar h1 { font-size: 1.6rem; margin: 0; }
.top-actions { display: flex; gap: 8px; }
.btn-primary { background: var(--accent); color: white; border: none; padding: 8px 18px; border-radius: 8px; font-family: system-ui, sans-serif; font-size: 0.85rem; font-weight: 600; cursor: pointer; }
.btn-outline { background: transparent; border: 1.5px solid rgba(16,36,31,0.2); color: var(--ink); padding: 8px 18px; border-radius: 8px; font-family: system-ui, sans-serif; font-size: 0.85rem; cursor: pointer; }

.meta-bar { display: flex; gap: 8px; align-items: center; font-family: system-ui, sans-serif; font-size: 0.85rem; color: var(--muted); margin-bottom: 1.5rem; }
.badge { font-size: 0.72rem; padding: 2px 10px; border-radius: 100px; font-weight: 600; }
.badge.ok{ background: rgba(39,174,96,0.12); color: #27ae60; }
.badge.warn{ background: rgba(243,156,18,0.12); color: #b8860b; }
.badge.info{ background: rgba(31,111,91,0.08); color: var(--accent); }

/* Empty state */
.empty-state { text-align: center; padding: 4rem 2rem; background: white; border: 1px solid rgba(16,36,31,0.08); border-radius: 14px; }
.empty-icon { font-size: 3rem; margin-bottom: 1rem; }
.empty-state h2 { font-size: 1.2rem; margin: 0 0 8px; }
.empty-state p { font-family: system-ui, sans-serif; font-size: 0.9rem; color: var(--muted); max-width: 480px; margin: 0 auto; line-height: 1.5; }

/* Provenance banner */
.minutes-body { background: white; border: 1px solid rgba(16,36,31,0.08); border-radius: 14px; padding: 28px; }
.provenance-banner { display: flex; gap: 12px; padding: 14px; background: rgba(31,111,91,0.04); border-radius: 10px; margin-bottom: 20px; }
.prov-icon { font-size: 1.4rem; flex-shrink: 0; }
.provenance-banner strong { font-size: 0.85rem; }
.provenance-banner p { font-family: system-ui, sans-serif; font-size: 0.8rem; color: var(--muted); margin: 2px 0 0; line-height: 1.4; }

/* Minutes meta */
.minutes-meta-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 20px; }
.minutes-meta-grid div { font-family: system-ui, sans-serif; font-size: 0.82rem; padding: 8px; background: rgba(0,0,0,0.015); border-radius: 6px; }
.minutes-meta-grid strong { font-size: 0.7rem; text-transform: uppercase; color: var(--muted); display: block; margin-bottom: 2px; }

.section-divider { border: 0; border-top: 1px solid rgba(0,0,0,0.05); margin: 16px 0; }

/* Minute sections */
.minute-section { padding: 14px 0; border-bottom: 1px solid rgba(0,0,0,0.04); }
.minute-section:last-child { border-bottom: none; }
.section-head { display: flex; gap: 10px; align-items: baseline; margin-bottom: 10px; }
.sec-num { font-weight: 700; font-size: 0.9rem; color: var(--accent); }
.section-head strong { font-size: 1rem; }
.sec-type { font-family: system-ui, sans-serif; font-size: 0.7rem; background: rgba(0,0,0,0.05); padding: 2px 8px; border-radius: 100px; color: var(--muted); margin-left: auto; }
.section-body p { font-family: system-ui, sans-serif; font-size: 0.85rem; line-height: 1.6; color: var(--ink); margin: 0 0 10px; }
.section-empty { padding: 10px; background: rgba(0,0,0,0.015); border-radius: 6px; margin: 8px 0; }
.section-empty p { font-family: system-ui, sans-serif; font-size: 0.8rem; color: var(--muted); margin: 0; }

.evidence-line { display: flex; gap: 6px; font-family: system-ui, sans-serif; font-size: 0.78rem; color: var(--muted); margin-bottom: 10px; }

.decision-box { margin: 10px 0; padding: 12px; border-left: 3px solid var(--accent); background: rgba(31,111,91,0.03); border-radius: 0 8px 8px 0; }
.dec-label { font-family: system-ui, sans-serif; font-size: 0.68rem; text-transform: uppercase; font-weight: 700; color: var(--accent); margin-bottom: 4px; }
.decision-box p { font-size: 0.9rem; font-weight: 600; margin: 0 0 6px; }
.vote-line { font-family: system-ui, sans-serif; font-size: 0.75rem; color: var(--muted); }

.confidence-line { display: flex; gap: 8px; align-items: center; font-family: system-ui, sans-serif; font-size: 0.72rem; color: #aaa; margin-top: 8px; }
.conf-dot { width: 8px; height: 8px; border-radius: 50%; }
.conf-high { background: #27ae60; }
.conf-medium { background: #f39c12; }

.notes-box { margin-top: 10px; padding: 10px; background: rgba(255,219,77,0.1); border-radius: 6px; }
.notes-box strong { font-size: 0.75rem; }
.notes-box p { font-family: system-ui, sans-serif; font-size: 0.8rem; color: var(--muted); margin: 4px 0 0; line-height: 1.4; }

/* Signature block */
.signature-block { margin-top: 20px; }
.signature-block h3 { font-size: 0.9rem; margin: 0 0 12px; }
.sig-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.sig-line { padding: 12px; background: rgba(0,0,0,0.015); border-radius: 8px; font-family: system-ui, sans-serif; }
.sig-label { font-size: 0.68rem; text-transform: uppercase; font-weight: 700; color: var(--muted); display: block; margin-bottom: 4px; }
.sig-name { font-size: 0.85rem; display: block; }
.sig-status { font-size: 0.75rem; color: var(--accent); }

@media (max-width: 600px) {
  .minutes-meta-grid { grid-template-columns: repeat(2, 1fr); }
  .sig-grid { grid-template-columns: 1fr; }
  .top-bar { flex-direction: column; gap: 10px; }
}
</style>
