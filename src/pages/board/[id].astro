---
// Board Detail Page — /board/[id]
import Layout from '../../layouts/Layout.astro';
import { getSession } from '../../session';
import { demoBoards, demoMembers, demoMeetings } from '../../lib/db';

const { id } = Astro.params;
const env = (Astro.locals.runtime as any)?.env;
const session = await getSession(Astro.request, env);

let board: any = null;
let members: any[] = [];
let meetings: any[] = [];
let isDemo = false;

if (env?.DB) {
  try {
    board = await env.DB.prepare('SELECT * FROM boards WHERE id = ?').bind(id).first();
    if (board) {
      const mRes = await env.DB.prepare('SELECT * FROM board_members WHERE board_id = ? ORDER BY created_at ASC').bind(id).all();
      members = mRes.results;
      const mtRes = await env.DB.prepare('SELECT * FROM meetings WHERE board_id = ? ORDER BY date DESC').bind(id).all();
      meetings = mtRes.results;
    }
  } catch { isDemo = true; }
}

if (!board && !isDemo) {
  // Fallback to demo data
  isDemo = true;
  board = demoBoards.find(b => b.id === id) || demoBoards[0];
  members = demoMembers.filter(m => m.boardId === board.id);
  meetings = demoMeetings.filter(m => m.boardId === board.id);
}

const isOwner = session && board;
---
<Layout title={board?.name || 'Styre'} activeNav="board">
  <div class="container">
    <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
      <div>
        <a href="/board" style="color: #065f46; font-size: 0.85rem; text-decoration: none;">← Tilbake til oversikt</a>
        <h1 style="font-size: 2rem; color: #065f46; margin-top: 0.5rem;">{board.name}</h1>
        {board.description && <p style="color: #666; margin-top: 0.25rem;">{board.description}</p>}
        <div style="margin-top: 0.75rem; display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <span class="badge badge-green">{board.status === 'pilot' ? 'Pilot' : board.status === 'active' ? 'Aktiv' : board.status}</span>
          <span style="font-size: 0.85rem; color: #888;">👥 {members.length} medlemmer</span>
          <span style="font-size: 0.85rem; color: #888;">📅 {meetings.length} møter</span>
        </div>
      </div>
      {isDemo && (
        <div style="background: #fffbeb; border: 1px solid #fde68a; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.85rem; color: #92400e;">
          📋 <strong>Demo-modus</strong> — Kontakt <a href="mailto:sales@styr.ing" style="color: #065f46;">sales@styr.ing</a> for full tilgang
        </div>
      )}
      {isOwner && (
        <div style="display: flex; gap: 0.5rem;">
          <button onclick="showAddMember()" class="btn-secondary" style="font-size: 0.85rem;">+ Medlem</button>
          <button onclick="showAddMeeting()" class="btn-primary" style="font-size: 0.85rem;">+ Møte</button>
        </div>
      )}
    </div>

    <!-- Members Section -->
    <section style="margin-bottom: 2.5rem;">
      <h2 style="font-size: 1.2rem; color: #333; margin-bottom: 1rem;">Styremedlemmer</h2>
      <div style="background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.08);">
        {members.length === 0 && <div style="padding: 2rem; text-align: center; color: #888;">Ingen medlemmer lagt til ennå.</div>}
        {members.map((m: any, i: number) => (
          <div style={`padding: 0.875rem 1rem; display: flex; justify-content: space-between; align-items: center; ${i < members.length - 1 ? 'border-bottom: 1px solid #f0f0f0;' : ''}`}>
            <div>
              <div style="font-weight: 600; font-size: 0.9rem;">{m.name}</div>
              <div style="color: #666; font-size: 0.8rem;">{m.role === 'leader' ? 'Styreleder' : m.role === 'deputy' ? 'Nestleder' : m.role === 'secretary' ? 'Sekretær' : m.role === 'observer' ? 'Observatør' : 'Styremedlem'}</div>
            </div>
            <div style="display: flex; align-items: center; gap: 1rem;">
              <span style="color: #888; font-size: 0.8rem;">{m.email}</span>
              {m.phone && <span style="color: #888; font-size: 0.8rem;">{m.phone}</span>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Meetings Section -->
    <section>
      <h2 style="font-size: 1.2rem; color: #333; margin-bottom: 1rem;">Møter</h2>
      <div style="background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.08);">
        {meetings.length === 0 && <div style="padding: 2rem; text-align: center; color: #888;">Ingen møter planlagt ennå.</div>}
        {meetings.map((m: any, i: number) => (
          <div style={`padding: 1rem; display: flex; justify-content: space-between; align-items: center; ${i < meetings.length - 1 ? 'border-bottom: 1px solid #f0f0f0;' : ''}`}>
            <div>
              <div style="font-weight: 600; font-size: 0.95rem;">{m.title}</div>
              <div style="color: #666; font-size: 0.8rem; margin-top: 0.1rem;">📅 {m.date}{m.time ? ` · ${m.time}` : ''}{m.location ? ` · ${m.location}` : ''}</div>
            </div>
            <div style="display: flex; align-items: center; gap: 1rem;">
              {m.document_count > 0 && <span style="color: #888; font-size: 0.8rem;">📄 {m.document_count} dokumenter</span>}
              <span class={`badge ${m.status === 'upcoming' || m.status === 'planned' ? 'badge-yellow' : m.status === 'completed' ? 'badge-green' : 'badge-blue'}`}>
                {m.status === 'planned' ? 'Planlagt' : m.status === 'upcoming' ? 'Kommende' : m.status === 'completed' ? 'Gjennomført' : m.status}
              </span>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
  .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 200; justify-content: center; align-items: center; }
  .modal.active { display: flex; }
  .modal-content { background: white; border-radius: 16px; padding: 2rem; max-width: 480px; width: 90%; max-height: 80vh; overflow-y: auto; }
  .modal-content h3 { color: #065f46; margin-bottom: 1.5rem; }
  .form-row { display: flex; flex-direction: column; gap: 1rem; }
  .form-row label { font-weight: 600; font-size: 0.85rem; }
  .form-row input, .form-row select { padding: 0.6rem; border: 1.5px solid #ddd; border-radius: 8px; font-size: 0.9rem; }
  .form-actions { display: flex; gap: 0.75rem; margin-top: 1.5rem; justify-content: flex-end; }
</style>

<div id="add-member-modal" class="modal">
  <div class="modal-content">
    <h3>Legg til styremedlem</h3>
    <form id="add-member-form" class="form-row">
      <label>Navn <input type="text" name="name" required /></label>
      <label>E-post <input type="email" name="email" required /></label>
      <label>Telefon <input type="tel" name="phone" /></label>
      <label>Rolle <select name="role">
        <option value="member">Styremedlem</option>
        <option value="leader">Styreleder</option>
        <option value="deputy">Nestleder</option>
        <option value="secretary">Sekretær</option>
        <option value="observer">Observatør</option>
      </select></label>
      <div class="form-actions">
        <button type="button" onclick="closeModal('add-member-modal')" class="btn-secondary">Avbryt</button>
        <button type="submit" class="btn-primary">Legg til</button>
      </div>
    </form>
  </div>
</div>

<div id="add-meeting-modal" class="modal">
  <div class="modal-content">
    <h3>Planlegg møte</h3>
    <form id="add-meeting-form" class="form-row">
      <label>Tittel <input type="text" name="title" required /></label>
      <label>Dato <input type="date" name="date" required /></label>
      <label>Tid <input type="time" name="time" /></label>
      <label>Sted <input type="text" name="location" /></label>
      <div class="form-actions">
        <button type="button" onclick="closeModal('add-meeting-modal')" class="btn-secondary">Avbryt</button>
        <button type="submit" class="btn-primary">Planlegg</button>
      </div>
    </form>
  </div>
</div>

<script>
  function showAddMember() { document.getElementById('add-member-modal')!.classList.add('active'); }
  function showAddMeeting() { document.getElementById('add-meeting-modal')!.classList.add('active'); }
  function closeModal(id: string) { document.getElementById(id)!.classList.remove('active'); }
  
  document.querySelectorAll('.modal').forEach(m => m.addEventListener('click', (e) => { if (e.target === m) closeModal(m.id); }));
  
  document.getElementById('add-member-form')?.addEventListener('submit', async (e) => {
    e.preventDefault(); const f = new FormData(e.target as HTMLFormElement);
    try {
      await fetch('/api/members', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ board_id: '{id}', name: f.get('name'), email: f.get('email'), phone: f.get('phone'), role: f.get('role') }) });
      window.location.reload();
    } catch (err) { alert('Feil ved lagring'); }
  });
  
  document.getElementById('add-meeting-form')?.addEventListener('submit', async (e) => {
    e.preventDefault(); const f = new FormData(e.target as HTMLFormElement);
    try {
      await fetch('/api/meetings', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ board_id: '{id}', title: f.get('title'), date: f.get('date'), time: f.get('time'), location: f.get('location') }) });
      window.location.reload();
    } catch (err) { alert('Feil ved lagring'); }
  });
</script>
