---
// Board Detail Page — static mode, demo data only
import Layout from '../../layouts/Layout.astro';
import { demoBoardsFixed, demoMembersFixed, demoMeetingsFixed } from '../../lib/db';

export function getStaticPaths() {
  return demoBoardsFixed.map(board => ({ params: { id: board.id } }));
}

const { id } = Astro.params;
const board = demoBoardsFixed.find(b => b.id === id) || demoBoardsFixed[0];
const members = demoMembersFixed.filter(m => m.board_id === id) || [];
const meetings = demoMeetingsFixed.filter(m => m.board_id === id) || [];
---
<Layout title={board.name} activeNav="boards">
  <div class="container" style="max-width: 960px; margin: 2rem auto; padding: 0 20px;">
    
    <!-- Back link -->
    <a href="/board" style="display: inline-flex; align-items: center; gap: 6px; color: var(--muted); font-family: system-ui, sans-serif; font-size: 0.875rem; text-decoration: none; margin-bottom: 1.5rem;">
      ← Tilbake til styrer
    </a>

    <!-- Header -->
    <div style="margin-bottom: 2rem;">
      <h1 style="font-size: 2rem; margin: 0 0 8px 0;">{board.name}</h1>
      <p style="font-family: system-ui, sans-serif; color: var(--muted); margin: 0;">
        {board.description || 'Styreportal for styremedlemmer'}
      </p>
    </div>

    <!-- Stats bar -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 2rem;">
      <div class="stat-card">
        <div class="stat-num">{members.length}</div>
        <div class="stat-label">Medlemmer</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{meetings.length}</div>
        <div class="stat-label">Møter</div>
      </div>
      <div class="stat-card">
        <div class="stat-num">{board.compliance_events || 0}</div>
        <div class="stat-label">Compliance-hendelser</div>
      </div>
    </div>

    <!-- Members section -->
    <section style="margin-bottom: 2rem;">
      <h2 style="font-size: 1.25rem; margin: 0 0 1rem 0; padding-bottom: 0.5rem; border-bottom: 2px solid rgba(16,36,31,0.08);">Styremedlemmer</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px;">
        {members.map(member => (
          <div class="member-card">
            <div class="member-avatar">{member.name.charAt(0)}</div>
            <div>
              <strong style="display: block; font-size: 0.95rem;">{member.name}</strong>
              <span style="font-family: system-ui, sans-serif; font-size: 0.8rem; color: var(--muted);">{member.email}</span>
              {member.role && (
                <span style="display: inline-block; margin-top: 4px; background: rgba(31,111,91,0.10); color: var(--accent); font-family: system-ui, sans-serif; font-size: 0.7rem; font-weight: 600; padding: 2px 10px; border-radius: 100px;">
                  {member.role}
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Meetings section -->
    <section style="margin-bottom: 2rem;">
      <h2 style="font-size: 1.25rem; margin: 0 0 1rem 0; padding-bottom: 0.5rem; border-bottom: 2px solid rgba(16,36,31,0.08);">Møter</h2>
      <div style="display: flex; flex-direction: column; gap: 12px;">
        {meetings.map(meeting => (
          <div class="meeting-card">
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 16px;">
              <div>
                <strong style="display: block; font-size: 1rem;">{meeting.title || 'Styremøte'}</strong>
                <span style="font-family: system-ui, sans-serif; font-size: 0.85rem; color: var(--muted);">
                  {meeting.date || ''} {meeting.time ? '· ' + meeting.time : ''}
                </span>
              </div>
              <div style="display: flex; gap: 8px;">
                <span class="meeting-badge {meeting.status === 'completed' ? 'badge-done' : 'badge-upcoming'}">
                  {meeting.status === 'completed' ? 'Gjennomført' : 'Planlagt'}
                </span>
              </div>
            </div>
            {meeting.minutes && (
              <div style="margin-top: 12px; padding: 16px; background: rgba(246,242,234,0.6); border-radius: 10px; font-family: system-ui, sans-serif; font-size: 0.85rem; color: var(--muted); line-height: 1.6;">
                {meeting.minutes}
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Pilot CTA -->
    <div style="text-align: center; padding: 2rem; background: rgba(31,111,91,0.06); border-radius: 16px; margin-bottom: 2rem;">
      <p style="font-family: system-ui, sans-serif; font-size: 0.9rem; color: var(--muted); margin: 0;">
        Dette er en demo. <a href="/login" style="color: var(--accent); font-weight: 600;">Logg inn</a> for 
        å administrere ditt eget styre.
      </p>
    </div>
  </div>
</Layout>

<style>
  .stat-card {
    background: white;
    border: 1px solid rgba(16,36,31,0.08);
    border-radius: 12px;
    padding: 20px;
    text-align: center;
  }
  .stat-num { font-size: 2rem; font-weight: 700; color: var(--accent); }
  .stat-label { font-family: system-ui, sans-serif; font-size: 0.8rem; color: var(--muted); margin-top: 4px; }
  
  .member-card {
    display: flex; align-items: center; gap: 14px;
    background: white;
    border: 1px solid rgba(16,36,31,0.08);
    border-radius: 12px;
    padding: 16px;
  }
  .member-avatar {
    width: 42px; height: 42px; border-radius: 50%;
    background: var(--accent); color: white;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 1.1rem; flex-shrink: 0;
  }
  
  .meeting-card {
    background: white;
    border: 1px solid rgba(16,36,31,0.08);
    border-radius: 12px;
    padding: 20px;
  }
  .meeting-badge {
    font-family: system-ui, sans-serif; font-size: 0.75rem; font-weight: 600;
    padding: 4px 12px; border-radius: 100px;
  }
  .badge-done { background: rgba(31,111,91,0.10); color: var(--accent); }
  .badge-upcoming { background: rgba(216,169,77,0.15); color: #8a7500; }
</style>
