---
interface Props { title: string; activeNav?: string; }
const { title, activeNav = '' } = Astro.props;
---
<!doctype html>
<html lang="no">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | Styr.ing</title>
  <meta name="description" content="Norsk styreportal og internkontroll for SMB. Digitaliser styrepapirer, compliance-kalender og internkontroll i én plattform. Fra 2 490 kr/mnd." />
  <meta name="keywords" content="styreportal, internkontroll, compliance, styreverktøy, norsk styre, Aksjeloven, GDPR, board portal, governance, Norway" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  <meta property="og:title" content="{title} | Styr.ing" />
  <meta property="og:description" content="Norsk styreportal og internkontroll for SMB. Fra 2 490 kr/mnd." />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Styr.ing" />
  <meta property="og:locale" content="nb_NO" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
  <link rel="llms-txt" href="/llms.txt" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Styr.ing",
    "url": "https://styr.ing",
    "description": "Norsk styreportal og internkontroll for SMB. Digitaliser styrepapirer, compliance-kalender og internkontroll i én plattform.",
    "foundingDate": "2026",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer support",
      "email": "ola@styr.ing"
    },
    "sameAs": []
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Styr.ing",
    "url": "https://styr.ing",
    "description": "Norsk styreportal og internkontroll for SMB",
    "inLanguage": "nb-NO",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://styr.ing/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Styr.ing",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Norsk styreportal og internkontrollverktøy for SMB. Board portal, compliance calendar, og internal control register.",
    "offers": {
      "@type": "Offer",
      "price": "2490.00",
      "priceCurrency": "NOK",
      "description": "Per styre per måned, ekskl. mva"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Hva er Styr.ing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Styr.ing er en norsk styreportal og internkontrollverktøy for SMB. Plattformen samler styredokumenter, compliance-kalender og internkontroll i én digital arbeidsflate."
        }
      },
      {
        "@type": "Question",
        "name": "Hva koster Styr.ing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Styr.ing koster 2 490 kr per måned per styre, ekskl. mva. Det er gratis pilotperiode frem til 30. juni 2026 for opptil 3 pilotkunder."
        }
      },
      {
        "@type": "Question",
        "name": "Hvilke norske regelverk støtter Styr.ing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Styr.ing støtter Aksjeloven, GDPR, Brønnøysundregistrene, Finanstilsynet, CSRD/ESRS og Internkontrollforskriften."
        }
      },
      {
        "@type": "Question",
        "name": "Hvordan kommer jeg i gang med Styr.ing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Send en forespørsel via kontaktskjemaet på styr.ing, så tar vi kontakt innen 1-2 arbeidsdager og setter opp ditt styre gratis i pilotperioden."
        }
      },
      {
        "@type": "Question",
        "name": "Er Styr.ing GDPR-kompatibel?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, Styr.ing er 100% norsk, GDPR-kompatibel, og driftes på sikker nettsky uten behov for lokal installasjon."
        }
      }
    ]
  }
  </script>
  <style>
    :root {
      --ink: #10241f;
      --muted: #5c6b65;
      --paper: #f6f2ea;
      --accent: #1f6f5b;
      --gold: #d8a94d;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: Georgia, "Times New Roman", serif;
      background: radial-gradient(circle at 18% 0%, #fff8df 0%, var(--paper) 45%, #dfe9e3 100%);
      color: var(--ink);
      line-height: 1.6;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { color: #0d4a3a; }

    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px clamp(20px,5vw,60px);
      background: rgba(246,242,234,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(16,36,31,0.08);
    }
    .logo { font-size: 1.25rem; font-weight: 700; letter-spacing: -0.02em; color: var(--ink); }
    .logo span { color: var(--accent); }
    .nav-links { display: flex; gap: 20px; list-style: none; font-family: system-ui, sans-serif; font-size: 0.85rem; align-items: center; }
    .nav-links a { color: var(--muted); font-weight: 500; }
    .nav-links a:hover { color: var(--accent); }
    .nav-links a.active { color: var(--accent); font-weight: 600; }
    .nav-cta {
      background: var(--accent); color: #fff;
      padding: 8px 18px; border-radius: 100px;
      font-family: system-ui, sans-serif; font-size: 0.8rem; font-weight: 600;
    }
    .nav-cta:hover { background: #0d4a3a; color: #fff; }

    .container { max-width: 1100px; margin: 0 auto; }
    [id] { scroll-margin-top: 80px; }

    footer {
      background: var(--ink); color: rgba(255,255,255,0.5);
      padding: 32px clamp(20px,5vw,60px); margin-top: 4rem;
      font-family: system-ui, sans-serif; font-size: 0.8rem;
    }
    .footer-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
    .footer-inner a { color: rgba(255,255,255,0.5); }
    .footer-inner a:hover { color: rgba(255,255,255,0.8); }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="logo">styr<span>.</span>ing</a>
    <ul class="nav-links" aria-label="Hovedmeny">
      <li><a href="/board" class={activeNav === 'boards' ? 'active' : ''}>Styreportal</a></li>
      <li><a href="/compliance" class={activeNav === 'compliance' ? 'active' : ''}>Compliance</a></li>
      <li><a href="/internkontroll" class={activeNav === 'internkontroll' ? 'active' : ''}>Internkontroll</a></li>
      <li><a href="/login">Logg inn</a></li>
      <li><a href="/signup" class="nav-cta" style="margin-left: 8px;">Registrer</a></li>
    </ul>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <div class="footer-inner">
      <div>© 2026 Styr.ing AS — Norsk styreportal og internkontroll</div>
      <div>
        <a href="mailto:ola@styr.ing">ola@styr.ing</a>
      </div>
    </div>
  </footer>
</body>
</html>
